# ===========================================
# Environment Configuration - ระบบงานทะเบียนครุภัณฑ์
# Asset Management System
# ===========================================
# Copy this file to .env and update values for your environment

# ===========================================
# Application Settings
# ===========================================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
POSTGRES_USER=assetuser
POSTGRES_PASSWORD=assetpass123
POSTGRES_DB=asset_registry
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://assetuser:assetpass123@db:5432/asset_registry

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Session Settings
# ===========================================
SESSION_SECRET=your-session-secret-key
SESSION_EXPIRES_IN=24h

# ===========================================
# File Upload Settings
# ===========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ===========================================
# Email/SMTP Configuration
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false
EMAIL_FROM=noreply@asset-system.com

# ===========================================
# Frontend Settings
# ===========================================
FRONTEND_URL=http://localhost:80
API_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:80,http://localhost:3000

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_MAX_FILES=30

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Monitoring & Health Check
# ===========================================
HEALTH_CHECK_PATH=/health
METRICS_PATH=/metrics
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3001
ELASTICSEARCH_URL=http://elasticsearch:9200

# ===========================================
# Backup Configuration
# ===========================================
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
AUTO_BACKUP_ENABLED=true

# ===========================================
# Security Settings
# ===========================================
BCRYPT_ROUNDS=10
PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5

# ===========================================
# Production Overrides (Uncomment for production)
# ===========================================
# NODE_ENV=production
# JWT_SECRET=change-to-a-secure-random-string-in-production
# POSTGRES_PASSWORD=use-secure-password-in-production
# LOG_LEVEL=warn
# RATE_LIMIT_MAX_REQUESTS=50
# CORS_ORIGINS=https://your-domain.com
